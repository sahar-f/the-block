# Optional — app works without these using local JSON fallback
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Required only for `npm run seed` (resync DB to data/vehicles.json).
# Get from Supabase dashboard → Settings → API. Never commit.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required only for `npm run enrich` (regenerate condition_summary fields).
# Get from console.anthropic.com → API Keys. Never commit.
# ANTHROPIC_API_KEY=sk-ant-...
